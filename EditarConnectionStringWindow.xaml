<Window x:Class="ImplementadorCUAD.EditarConnectionStringWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajustar connection string de CUAD"
        Width="720"
        Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Icon="pack://application:,,,/Resources/icono.ico"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Pegá o escribí el connection string para la base CUAD. Se guardará en Configuracion.xml (&lt;Conexiones&gt;&lt;Cuad connectionString=&quot;...&quot; /&gt;)."
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="ConnectionStringTextBox"
                 Grid.Row="1"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 FontFamily="Consolas"
                 FontSize="12"
                 Margin="0,0,0,8"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="Red"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"
                       TextWrapping="Wrap"/>

            <Button Content="Probar y guardar"
                    Width="130"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnProbarYGuardarClick"/>
            <Button Content="Cancelar"
                    Width="90"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

