<Window x:Class="Implementador.Presentation.Dialogs.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de conexión"
        Height="240"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/icono.ico"
        Background="#10141D">
    <Border Style="{StaticResource PanelCardStyle}" Margin="1,0,0,1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                   Text="Ingrese el connection string"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />

            <TextBlock Grid.Row="1"
                   Text="{Binding WarningMessage}"
                   Foreground="#FBBF24"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WarningMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WarningMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBox x:Name="ConnectionStringTextBox"
                 Grid.Row="2"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 Background="{StaticResource PanelBrush}"
                 BorderBrush="#475569"
                 BorderThickness="1"
                 VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
                <Button Width="100"
                    Margin="0,0,8,0"
                    Content="Cancelar"
                    Style="{StaticResource OutlineButtonStyle}" Height="33" HorizontalAlignment="Center" VerticalAlignment="Center" IsCancel="True" />
                <Button Width="97"
                    Content="Conectar"
                    IsDefault="True"
                    Height="34"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnConnectClick" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
