<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="MigradorCUAD.MainWindow"
        Title="MigradorCUAD"
        Height="300"
        Width="500">

    <Grid Margin="20">
        <StackPanel Width="400" HorizontalAlignment="Left">

            <TextBlock Text="Empleador"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

            <ComboBox ItemsSource="{Binding Empleadores}"
                  SelectedItem="{Binding EmpleadorSeleccionado}"
                  DisplayMemberPath="Nombre"
                  Height="30"
                  Margin="0,0,0,20"/>

            <TextBlock Text="Entidad"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

            <ComboBox ItemsSource="{Binding Entidades}"
                  SelectedItem="{Binding EntidadSeleccionada}"
                  DisplayMemberPath="Nombre"
                  Height="30"/>

        </StackPanel>
    </Grid>


</Window>
