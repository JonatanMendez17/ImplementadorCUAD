<Window x:Class="MigradorCUAD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="av"
        Title="Migrador CUAD"
        Height="634"
        Width="1000"
        MinHeight="670"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#FF101010">

    <Window.Resources>
        <!-- Tipografía y colores base -->
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
        <SolidColorBrush x:Key="AccentBrushLight" Color="#FF60A5FA" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF1F2933" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FF374151" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF9FAFB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF9CA3AF" />

        <!-- Estilo general para botones -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrushLight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrushLight}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo moderno para ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="Background" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="#FFCBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <Grid Margin="10,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="ContentSite"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                                <TextBlock x:Name="PlaceholderText"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="#FF6B7280"
                                           Text="Seleccionar"
                                           Visibility="Hidden"
                                           IsHitTestVisible="False" />

                                <Path Grid.Column="1"
                                      Width="10"
                                      Height="6"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      Fill="#FF475569"
                                      Data="M 0 0 L 5 6 L 10 0 Z" />
                            </Grid>

                            <ToggleButton Grid.ColumnSpan="2"
                                          Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          OverridesDefaultStyle="True"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="10"
                                        Background="#FFFFFFFF"
                                        BorderBrush="#FFCBD5E1"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Margin="4"
                                                  SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="34" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#FFF1F5F9" />
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF94A3B8" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF60A5FA" />
                                <Setter TargetName="ComboBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="SelectedIndex" Value="-1">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="SelectedIndex" Value="0">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para los ítems del ComboBox -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFE2E8F0" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFBFDBFE" />
                                <Setter Property="Foreground"
                                        Value="Black" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para TextBlock de título de sección -->
        <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!-- Estilo para etiquetas secundarias -->
        <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <Grid Margin="19,16,16,60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="576.74" />
            <RowDefinition Height="0*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                <TextBlock Text="Migrador CUAD"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Cargar los archivos, validá y copiá a base de datos"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </DockPanel>

        <!-- Contenido principal -->
        <Grid Margin="0,0,0,21">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" MinWidth="360" />
                <ColumnDefinition Width="2.9*" MinWidth="500" />
            </Grid.ColumnDefinitions>

            <!-- Columna izquierda: selección de empleador, entidad y archivos -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0,0,10,0">
                <StackPanel>
                    <!-- Selección de Empleador y Entidad -->
                    <TextBlock Text="Contexto de Migración"
                               Style="{StaticResource SectionTitleTextBlockStyle}" />

                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Entidad -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Entidad"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Entidades}"
                                      SelectedItem="{Binding EntidadSeleccionada}"
                                      DisplayMemberPath="Nombre" />
                        </StackPanel>

                        <!-- Empleador -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Empleador"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Empleador}"
                                      SelectedItem="{Binding EmpleadorSeleccionado}"
                                      DisplayMemberPath="Nombre" />
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,4,0,12" />

                    <!-- Selección de archivos -->
                    <TextBlock Text="Archivos de Migración"
                               Style="{StaticResource SectionTitleTextBlockStyle}" />

                    <StackPanel Margin="0,4,0,0">
                        <!-- Categorías -->
                        <StackPanel Margin="0,4,0,6">
                            <Button Content="Seleccionar Categorías"
                                    Command="{Binding SeleccionarCategoriasCommand}" />
                            <TextBlock Text="{Binding ArchivoCategorias}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>

                        <!-- Padrón de Socios-->
                        <StackPanel Margin="0,4,0,6">
                            <Button Content="Seleccionar Padrón de Socios"
                                    Command="{Binding SeleccionarPadronCommand}" />
                            <TextBlock Text="{Binding ArchivoPadron}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>

                        <!-- Consumos -->
                        <StackPanel Margin="0,4,0,6">
                            <Button Content="Seleccionar Consumos"
                                    Command="{Binding SeleccionarConsumosCommand}" />
                            <TextBlock Text="{Binding ArchivoConsumos}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>

                        <!-- Consumos Detalle -->
                        <StackPanel Margin="0,4,0,6">
                            <Button Content="Seleccionar Consumos Detalle"
                                    Command="{Binding SeleccionarConsumosDetalleCommand}" />
                            <TextBlock Text="{Binding ArchivoConsumosDetalle}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>

                        <!-- Servicios -->
                        <StackPanel Margin="0,4,0,6">
                            <Button Content="Seleccionar Servicios"
                                    Command="{Binding SeleccionarServiciosCommand}" />
                            <TextBlock Text="{Binding ArchivoServicios}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>

                        <!-- Catálogo de Servicios -->
                        <StackPanel Margin="0,4,0,0">
                            <Button Content="Seleccionar Catálogo de Servicios"
                                    Command="{Binding SeleccionarCatalogoServiciosCommand}" />
                            <TextBlock Text="{Binding ArchivoCatalogoServicios}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Columna derecha: validación, logs y progreso -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Acciones -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="Validar archivos"
                                Command="{Binding ValidarCommand}"
                                Width="150" Height="30" Margin="0,0,8,8" />
                        <Button Content="Migrar datos"
                                Command="{Binding CopiarCommand}"
                                Width="150" Height="30" Margin="0,0,8,8" />
                        <Button Content="Limpiar base entidad"
                                Command="{Binding LimpiarBaseEntidadCommand}"
                                Width="150" Height="30" Margin="0,0,8,8" />
                        <Button Content="Exportar log"
                                Command="{Binding ExportarLogCommand}"
                                Width="150" Height="30" Margin="0,0,0,8" />
                    </WrapPanel>

                    <!-- Logs -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Log de validación"
                                   Style="{StaticResource SectionTitleTextBlockStyle}" />
                        <Border BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="#FF020617"
                                Padding="4"
                                Margin="0,4,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Logs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- Progreso -->
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock Text="Progreso de migración"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4" />
                        <ProgressBar Height="18"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding Progreso}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
