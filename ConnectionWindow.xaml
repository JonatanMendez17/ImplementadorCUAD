<Window x:Class="ImplementadorCUAD.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de conexión"
        Height="220"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/icono.ico"
        Background="#10141D">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Ingrese el connection string"
                   Foreground="#E5E7EB"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1"
                   Foreground="#9CA3AF"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" ><Run Text="La aplicación usará esta conexión para "/><Run Language="es-es" Text="acceder a la base de datos"/><Run Text="."/></TextBlock>

        <TextBox x:Name="ConnectionStringTextBox"
                 Grid.Row="2"
                 Margin="0,0,0,12"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Foreground="#E5E7EB"
                 Background="#1E293B"
                 BorderBrush="#4B5563"
                 BorderThickness="1"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="100"
                    Margin="0,0,8,0"
                    Content="Cancelar"
                    IsCancel="True" />
            <Button Width="140"
                    Content="Conectar"
                    IsDefault="True"
                    Click="OnConnectClick" />
        </StackPanel>
    </Grid>
</Window>

