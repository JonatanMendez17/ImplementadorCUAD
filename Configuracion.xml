<Configuracion>

  <!--CONFIGURACIÓN DE COLUMNAS PARA ARCHIVOS
  Esto permite adaptar la importación a diferentes formatos de archivo sin necesidad de modificar el código de la aplicación.

  1. Los archivos que se cargan en la aplicación deben contener, como mínimo, las columnas definidas en esta configuración.
  2. Si una columna no está presente en el archivo a cargar, se puede deshabilitar comentando su columna en este archivo de configuración.
  3. Si el archivo contiene un nombre de columna diferente al esperado, se agregar como un nuevo alias dentro este archivo configuración. -->-->


  <!-- Archivo de categorías de socios:-->
  <Archivo nombre="Categorias">
    <Columnas>
      <Columna nombre="Entidad" clave="Entidad" tipo="texto" largoMaximo="20" requerida="true">
        <Alias>Entidad</Alias>
        <Alias>Institucion</Alias>
        <Alias>Institución</Alias>
      </Columna>
      <Columna nombre="Código Categoría" tipo="texto" largoMaximo="10">
        <Alias>Código Categoría</Alias>
      </Columna>
      <Columna nombre="Categoría" tipo="texto" largoMaximo="50">
        <Alias>Categoría</Alias>
      </Columna>
      <Columna nombre="Descripción Categoría" tipo="texto" largoMaximo="100">
        <Alias>Descripción Categoría</Alias>
      </Columna>
      <Columna nombre="Categoría Predeterminada" tipo="texto" largoMaximo="1">
        <Alias>Categoría Predeterminada</Alias>
      </Columna>
      <Columna nombre="Monto CS" tipo="decimal" largoMaximo="15">
        <Alias>Monto CS</Alias>
      </Columna>
      <Columna nombre="Concepto Descuento" tipo="int" largoMaximo="10">
        <Alias>Concepto Descuento</Alias>
      </Columna>
    </Columnas>
  </Archivo>

  <!-- Archivo padrón de socio -->
  <Archivo nombre="Padron">
    <Columnas>
      <Columna nombre="Entidad" clave="Entidad" tipo="texto" largoMaximo="20" requerida="true">
        <Alias>Entidad</Alias>
        <Alias>Institucion</Alias>
        <Alias>Institución</Alias>
      </Columna>
      <Columna nombre="Nro Socio" tipo="int" largoMaximo="10">
        <Alias>Nro Socio</Alias>
      </Columna>
      <Columna nombre="Fecha Alta Socio" tipo="fecha" largoMaximo="20">
        <Alias>Fecha Alta Socio</Alias>
      </Columna>
      <Columna nombre="Documento" tipo="texto" largoMaximo="20">
        <Alias>Documento</Alias>
      </Columna>
      <!--<Columna nombre="CUIT" tipo="texto" largoMaximo="11">
        <Alias>CUIT</Alias>
      </Columna>-->
      <!--<Columna nombre="Beneficio" tipo="texto" largoMaximo="20">
        <Alias>Beneficio</Alias>
      </Columna>-->
      <Columna nombre="Código Categoría" tipo="texto" largoMaximo="10">
        <Alias>Código Categoría</Alias>
      </Columna>
    </Columnas>
  </Archivo>

  <!-- Archivo de consumo -->
  <Archivo nombre="Consumos">
    <Columnas>
      <Columna nombre="Entidad" clave="Entidad" tipo="texto" largoMaximo="20" requerida="true">
        <Alias>Entidad</Alias>
        <Alias>Institucion</Alias>
        <Alias>Institución</Alias>
      </Columna>
      <Columna nombre="Nro Socio" tipo="int" largoMaximo="10">
        <Alias>Nro Socio</Alias>
      </Columna>
      <Columna nombre="CUIT" tipo="texto" largoMaximo="11">
         para configuracion de columna 
        <Alias>CUIT</Alias>
      </Columna>
      <Columna nombre="Beneficio" tipo="texto" largoMaximo="20">
         para configuracion de columna 
        <Alias>Beneficio</Alias>
      </Columna>
      <Columna nombre="Código Consumo" clave="Codigo Consumo" tipo="texto" largoMaximo="20">
        <Alias>Código Consumo</Alias>
        <Alias>Código</Alias>
        <Alias>Codigo</Alias>
        <Alias>Consumo</Alias>
      </Columna>
      <Columna nombre="Cuotas Pendientes" tipo="int" largoMaximo="5">
        <Alias>Cuotas Pendientes</Alias>
      </Columna>
      <Columna nombre="Monto Deuda" tipo="decimal" largoMaximo="15">
        <Alias>Monto Deuda</Alias>
      </Columna>
      <Columna nombre="Concepto Descuento" tipo="int" largoMaximo="10">
        <Alias>Concepto Descuento</Alias>
      </Columna>
    </Columnas>
  </Archivo>

  <!-- Archivo de consumo detalle -->
  <Archivo nombre="ConsumosDetalle">
    <Columnas>
      <Columna nombre="Entidad" clave="Entidad" tipo="texto" largoMaximo="20" requerida="true">
        <Alias>Entidad</Alias>
        <Alias>Institucion</Alias>
        <Alias>Institución</Alias>
      </Columna>
      <Columna nombre="Código Consumo" tipo="int" largoMaximo="10">
        <Alias>Código Consumo</Alias>
      </Columna>
      <Columna nombre="Nro Cuota" tipo="int" largoMaximo="5">
        <Alias>Nro Cuota</Alias>
      </Columna>
      <Columna nombre="Fecha Vencimiento" tipo="fecha" largoMaximo="20">
        <Alias>Fecha Vencimiento</Alias>
      </Columna>
      <Columna nombre="Monto" tipo="decimal" largoMaximo="15">
        <Alias>Monto</Alias>
      </Columna>
    </Columnas>
  </Archivo>

  <!-- Archivo de consumo servicio -->
  <Archivo nombre="Servicios">
    <Columnas>
      <Columna nombre="Entidad" clave="Entidad" tipo="texto" largoMaximo="20" requerida="true">
        <Alias>Entidad</Alias>
        <Alias>Institucion</Alias>
        <Alias>Institución</Alias>
      </Columna>
      <Columna nombre="Nro de Socio" tipo="int" largoMaximo="10">
        <Alias>Nro Socio</Alias>
      </Columna>
      <Columna nombre="CUIT" tipo="texto" largoMaximo="11">
        <Alias>CUIT</Alias>
      </Columna>
      <Columna nombre="Nro Beneficio" tipo="texto" largoMaximo="20">
         para configuracion de columna 
        <Alias>Nro Beneficio</Alias>
      </Columna>
      <Columna nombre="Código Consumo" tipo="int" largoMaximo="10">
        <Alias>Código Consumo</Alias>
      </Columna>
      <Columna nombre="Importe Cuota" tipo="decimal" largoMaximo="15">
        <Alias>Importe Cuota</Alias>
      </Columna>
      <Columna nombre="Concepto Descuento" tipo="int" largoMaximo="10">
        <Alias>Concepto Descuento</Alias>
      </Columna>
    </Columnas>
  </Archivo>

  <!-- Archivo catálogo de servicios -->
  <Archivo nombre="CatalogoServicios">
    <Columnas>
      <Columna nombre="Entidad" clave="Entidad" tipo="texto" largoMaximo="10" requerida="true">
        <Alias>Entidad</Alias>
        <Alias>Institucion</Alias>
        <Alias>Institución</Alias>
      </Columna>
      <Columna nombre="Servicio" tipo="texto" largoMaximo="100">
        <Alias>Servicio</Alias>
      </Columna>
      <Columna nombre="Importe" tipo="decimal" largoMaximo="15">
        <Alias>Importe</Alias>
      </Columna>
      <Columna nombre="Comentarios / Info de Servicio" tipo="texto" largoMaximo="255">
        <Alias>Comentarios / Info de Servicio</Alias>
      </Columna>
    </Columnas>
  </Archivo>

  <!-- CONEXIONES A BASES DE DATOS
  Cuad: base CUAD (solo lectura)
  ConexionBase: servidor y autenticación comunes. Se combina con baseDatos de cada empleador.
  Empleador: cada uno apunta a su base (baseDatos) donde se importan los 6 archivos.-->
  
  <Conexiones>
    <Cuad connectionString="Server=localhost;Database=CUAD;Trusted_Connection=True;TrustServerCertificate=True;" />
    <ConexionBase connectionString="Server=localhost;Trusted_Connection=True;TrustServerCertificate=True;" />
      <Empleador nombre="BDI" baseDatos="BDI_Test" />
      <Empleador nombre="ACTIVOS" baseDatos="BDI_Activos" />
      <Empleador nombre="PASIVOS" baseDatos="BDI_Pasivos" />
      <Empleador nombre="LEY 5110" baseDatos="BDI_Ley5110" />
      <Empleador nombre="MALVINAS" baseDatos="BDI_Malvinas" />
  </Conexiones>

</Configuracion>
